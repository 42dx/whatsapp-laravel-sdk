<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    backupGlobals="false"
    colors="true"
    processIsolation="false"
    stopOnFailure="false"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.1/phpunit.xsd"
    cacheDirectory=".phpunit.cache"
    backupStaticProperties="false"
>
    <testsuites>
        <testsuite name="Api/Integration Test Suite">
            <directory suffix="Test.php">tests/Integration</directory>
        </testsuite>
        <testsuite name="Unit Test Suite">
            <directory suffix="Test.php">tests/Unit</directory>
        </testsuite>
    </testsuites>
    <php>
        <env name="WPP_API_VERSION" value="v25.0"/>
        <env name="WPP_BUSINESS_ID" value="some-id"/>
        <env name="APP_DEBUG" value="false"/>
        <env name="LOG_LEVEL" value="error"/>
        <env name="WPP_BUSINESS_PHONE_ID" value="000000"/>
        <env name="WPP_BUSINESS_PHONE_NUMBER" value="999999999999"/>
        <env name="WPP_SERVER_URL" value="http://some-server.com"/>
        <env name="WPP_TOKEN" value="some-token"/>
        <env name="WPP_WEBHOOK_VERIFY" value="some-verify"/>
        <env name="WPP_WEBHOOK_ROUTE" value="/webhooks/whatsapp"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
    </php>
    <coverage>
        <report>
            <html outputDirectory="build/coverage" lowUpperBound="50" highLowerBound="80"/>
        </report>
    </coverage>
    <source>
        <include>
            <directory suffix=".php">./src</directory>
        </include>

        <exclude>
            <file>src/RouteServiceProvider.php</file>
            <file>src/WhatsappServiceProvider.php</file>
        </exclude>
    </source>
</phpunit>
